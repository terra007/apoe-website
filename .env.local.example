# ============================================================
# APÖ – Environment Variables
# Copy this file to .env.local and fill in the values.
# .env.local is in .gitignore and will NOT be committed.
# ============================================================

# E-Mail provider (Resend - https://resend.com)
# Get your API key at: resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Recipient address for contact form submissions
CONTACT_EMAIL_TO=office@apoesterreich.at

# ============================================================
# Supabase (Admin-Auth + Storage)
# Werte findest du in deinem Supabase-Projekt unter Settings → API
# ============================================================

# Project URL (z.B. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co

# Anon/Public Key (sicher für den Browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-key-hier

# ============================================================
# Upstash Redis (Rate Limiting für Kontaktformular)
# Kostenloses Konto: upstash.com → Create Database → REST API → .env
# ============================================================
UPSTASH_REDIS_REST_URL=https://deine-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=dein-token-hier

# Startseiten-Video (öffentliche Supabase-Storage-URL, z.B. https://xxx.supabase.co/storage/v1/object/public/videos/home.mp4)
# Wenn leer, wird kein Video-Block angezeigt.
NEXT_PUBLIC_HOME_VIDEO_URL=
# Poster-Bild (Screenshot des ersten Frames, JPG/PNG, ebenfalls in Supabase Storage)
NEXT_PUBLIC_HOME_VIDEO_POSTER_URL=

# ============================================================
# Vercel Environment Variables (set in Vercel Dashboard)
# Project Settings → Environment Variables
# ============================================================
# RESEND_API_KEY
# CONTACT_EMAIL_TO
# ADMIN_PASSWORD
# ADMIN_SESSION_SECRET
